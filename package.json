  "private": true,
  "resolutions": {
    "@typescript-eslint/typescript-estree": "^8.0.0",
    "@typescript-eslint/scope-manager": "^8.0.0",
    "@typescript-eslint/types": "^8.0.0",
    "@typescript-eslint/visitor-keys": "^8.0.0"
