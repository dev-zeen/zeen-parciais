{
  "name": "parciais-fc",
  "main": "expo-router/entry",
  "version": "0.7.0",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "npx expo lint",
    "typecheck": "tsc --noEmit",
    "rebuild": "npx expo prebuild --clean",
    "rebuild-test": "npx expo prebuild --clean && npm run ios",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:prod:android": "eas build --platform android --profile production",
    "build:prod:ios": "eas build --platform ios --profile production",
    "build:prod:all": "eas build --platform all --profile production",
    "submit:android": "eas submit --platform android --latest",
    "submit:ios": "eas submit --platform ios --latest",
    "update:prod": "eas update --branch production --message",
    "credentials:ios": "eas credentials --platform ios",
    "credentials:android": "eas credentials --platform android"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/metro-runtime": "^6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.99.2",
    "axios": "^1.4.0",
    "date-fns": "^2.30.0",
    "expo": "~54.0.33",
    "expo-constants": "^18.0.13",
    "expo-font": "~14.0.11",
    "expo-insights": "~0.10.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-dialog": "^9.3.0",
    "react-native-error-boundary": "^1.2.9",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-select-dropdown": "^3.4.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.15.0",
    "zustand": "^4.3.9"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/js-cookie": "^3.0.3",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-n": "^16.0.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.17",
    "prettier": "^3.8.3",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "3.3.2",
    "typescript": "^5.1.3"
